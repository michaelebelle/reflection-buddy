APP_NAME=Reflection Buddy
DEBUG=false

# ── Database ───────────────────────────────────────────────────────────────
# Local dev: SQLite (no setup needed)
DATABASE_URL=sqlite:///./journal.db
# Production (Neon / any Postgres):
# DATABASE_URL=postgresql://user:password@host/dbname

# ── Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me-in-production

# ── AI (optional) ──────────────────────────────────────────────────────────
# Reflection question generation — https://console.anthropic.com
# Without this, the app falls back to mood-based heuristic prompts.
# ANTHROPIC_API_KEY=sk-ant-...

# Entry embeddings + semantic search — https://platform.openai.com/api-keys
# Without this, entries save normally but /entries/search returns no results.
# OPENAI_API_KEY=sk-proj-...
